{
  "name": "t-agent",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r run typecheck",
    "example": "node --env-file=.env --import tsx examples/basic-agent.ts",
    "example:subagent": "node --env-file=.env --import tsx examples/sub-agent.ts",
    "example:approval": "node --env-file=.env --import tsx examples/approval-and-memory.ts",
    "publish:all": "pnpm build && pnpm -r publish --no-git-checks"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "vitest": "^3.2.0"
  }
}
